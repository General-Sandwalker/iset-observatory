{
  "name": "iset-observatory-backend",
  "version": "1.0.0",
  "description": "Backend API for ISET Tozeur Adaptive Digital Observatory",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "exceljs": "^4.4.0",
    "express": "^4.21.1",
    "groq-sdk": "^0.37.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.0",
    "papaparse": "^5.5.3",
    "pg": "^8.13.1",
    "pg-pool": "^3.7.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/multer": "^2.0.0",
    "@types/node": "^22.10.0",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.11.10",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.7.2"
