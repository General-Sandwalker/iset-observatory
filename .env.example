# ─── Database (local Docker Compose) ────────────────────────
# Used only when none of the DATABASE_URL / POSTGRES_URL variables are set.
DATABASE_HOST=db
DATABASE_PORT=5432
DATABASE_USER=observatory
DATABASE_PASSWORD=observatory_secret
DATABASE_NAME=observatory_db

# ─── Database (Railway / PaaS) ───────────────────────────────
# Set ONE of these — whichever name Railway injects for your Postgres plugin.
# On Railway: go to backend service → Variables → Add Variable Reference → pick Postgres → choose the URL variable.
# Supported names (checked in order):
#   DATABASE_URL
#   DATABASE_PRIVATE_URL   ← preferred for internal Railway networking
#   POSTGRES_URL
#   POSTGRES_PRIVATE_URL
#
# DATABASE_PRIVATE_URL=postgresql://user:password@postgres.railway.internal:5432/railway
# DATABASE_URL=postgresql://user:password@postgres.railway.internal:5432/railway

# ─── Backend ─────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
JWT_SECRET=change-me-in-production

# Comma-separated list of allowed frontend origins
# Local:      http://localhost:5173
# Production: https://your-app.vercel.app
CORS_ORIGIN=http://localhost:5173

# ─── AI (Groq) ──────────────────────────────────────────────
GROQ_API_KEY=
GROQ_MODEL=qwen/qwen3-32b

# ─── Super Admin Seed ────────────────────────────────────────
SUPER_ADMIN_EMAIL=admin@iset-tozeur.tn
SUPER_ADMIN_PASSWORD=Admin@123!

